# E2B API key — required. Get yours at https://e2b.dev
E2B_API_KEY=

# E2B sandbox template ID — the template pre-loaded with Node.js and the Temporal CLI.
# Create a template via `e2b template build` and paste the resulting ID here.
E2B_TEMPLATE_ID=

# Pooled Neon Postgres runtime connection string.
DATABASE_URL=

# Direct, unpooled Neon Postgres migration connection string. Used by operators
# and CI for `bun run db:migrate`; do not set this as a Fly runtime secret.
MIGRATION_DATABASE_URL=

# SHA-256 hash of the shared demo token. Store the raw token outside the repo.
SANDMAN_DEMO_TOKEN_SHA256=

# Signing secret for the HttpOnly demo session cookie.
SANDMAN_SESSION_SECRET=

# Sandbox session lifetime in milliseconds. Sandboxes are automatically terminated
# after this duration. Default: 300000 (5 minutes).
SANDMAN_SESSION_TTL_MS=300000

# Conservative production demo limits.
SANDMAN_MAX_ACTIVE_SANDBOXES=20
SANDMAN_MAX_ACTIVE_SANDBOXES_PER_SESSION=1
SANDMAN_SESSION_CREATIONS_PER_TOKEN_PER_HOUR=5
