# E2B API key — required. Get yours at https://e2b.dev
E2B_API_KEY=

# E2B sandbox template ID — the template pre-loaded with Node.js and the Temporal CLI.
# Production requires this. Create a template with:
# `bunx e2b template create sandman --path . --dockerfile e2b.Dockerfile`
# Then publish/list it and paste the resulting ID here.
E2B_TEMPLATE_ID=

# Pooled Neon Postgres runtime connection string.
DATABASE_URL=

# Direct, unpooled Neon Postgres migration connection string. Used by operators
# and CI for `bun run db:migrate`; do not set this as a Fly runtime secret.
MIGRATION_DATABASE_URL=

# SHA-256 hash of the shared invite code.
# Invite codes are currently disabled. Set SANDMAN_INVITE_CODE_REQUIRED=true to
# require the shared invite code again.
# Generate a raw invite code with `openssl rand -base64 24`, store it outside the
# repo, then hash it with:
# `printf '%s' '<raw-invite-code>' | shasum -a 256 | awk '{print $1}'`
SANDMAN_INVITE_CODE_REQUIRED=false
SANDMAN_DEMO_TOKEN_SHA256=

# Signing secret for the HttpOnly demo session cookie.
SANDMAN_SESSION_SECRET=

# Sandbox session lifetime in milliseconds. Sandboxes are automatically terminated
# after this duration. Default: 900000 (15 minutes).
SANDMAN_SESSION_TTL_MS=900000

# Conservative production demo limits.
SANDMAN_MAX_ACTIVE_SANDBOXES=20
SANDMAN_MAX_ACTIVE_SANDBOXES_PER_SESSION=1
SANDMAN_SANDBOX_CREATIONS_PER_VISITOR_PER_HOUR=5
