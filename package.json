{
	"name": "sandman",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint .",
		"test": "vitest run",
		"test:workflows": "vitest run --root sandbox-template --passWithNoTests",
		"test:e2e": "playwright test",
		"smoke:sandbox": "bun src/lib/server/sandbox/smoke.ts",
		"proof:preview": "bun src/lib/server/proxy/proof.ts",
		"smoke:e2e": "bun src/lib/server/sandbox/smoke-e2e.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"deploy:status": "bun scripts/deploy.ts",
		"docs:demo": "bun src/lib/content/docs-generator.ts",
		"docs:demo:check": "bun src/lib/content/docs-generator.ts --check"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.60.0",
		"@sveltejs/adapter-auto": "next",
		"@sveltejs/adapter-node": "6.0.0-next.0",
		"@sveltejs/kit": "next",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.8",
		"drizzle-kit": "^0.31.10",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1"
	},
	"dependencies": {
		"@lostgradient/cinder": "0.4.1",
		"@neondatabase/serverless": "^1.1.0",
		"@temporalio/activity": "^1.18.1",
		"@temporalio/client": "^1.18.1",
		"@temporalio/common": "^1.18.1",
		"@temporalio/testing": "^1.18.1",
		"@temporalio/worker": "^1.18.1",
		"@temporalio/workflow": "^1.18.1",
		"drizzle-orm": "^0.45.2",
		"e2b": "^2.31.0",
		"monaco-editor": "^0.55.1"
	},
	"trustedDependencies": [
		"@swc/core",
		"protobufjs"
	]
}
